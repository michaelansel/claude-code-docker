JSON
# Track claude calls
cat > "$TEST_DIR/claude" <<'STUB'
#!/usr/bin/env bash
if [[ "${1:-}" == "plugin" && "${2:-}" == "marketplace" ]]; then
    echo "MARKETPLACE_UPDATE: $*" >> "$HOME/claude-calls.log"
    exit 0
