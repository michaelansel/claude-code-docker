JSON
write_rt_stubs "$(cat <<STUB
#!/usr/bin/env bash
if [[ "\${1:-}" == "image" && "\$*" == *"--format"* ]]; then echo "$expected_hash"; exit 0; fi
if [[ "\${1:-}" == "image" ]]; then exit 0; fi
if [[ "\${1:-}" == "stop" ]]; then exit 0; fi
# Check actual permission bits of the agent ID file while it still exists.
# Must have "others write" bit (002) so the container node user (UID 1000 = "others") can write.
# -w only tells us if the stub process (owner) can write, which is always true — check bits directly.
for arg in "\$@"; do
    if [[ "\$arg" =~ ^C3PO_AGENT_ID_FILE=/home/node/.claude/(.+)\$ ]]; then
        file="\$HOME/.claude-docker/agents/watcher/\${BASH_REMATCH[1]}"
        perm=\$(stat -f %Lp "\$file" 2>/dev/null || stat -c %a "\$file" 2>/dev/null)
        echo "\$perm" >> "\$HOME/rt-perm.log"
    fi
done
exit 0
STUB
)"
timeout 3 bash "$UNDER_TEST" --no-stream agent run watcher 2>/dev/null || true
if [[ -f "$TEST_DIR/rt-perm.log" ]]; then
    perm=$(cat "$TEST_DIR/rt-perm.log" | head -1 | tr -d '[:space:]')
    if (( (8#$perm & 8#002) != 0 )); then
        echo "  PASS: agent ID file has others-write bit (perm=$perm)"
        PASS=$((PASS + 1))
    else
        echo "  FAIL: agent ID file missing others-write bit (perm=$perm) — umask stripped it"
        FAIL=$((FAIL + 1))
    fi
else
    echo "  FAIL: container never ran or C3PO_AGENT_ID_FILE arg not found"
    FAIL=$((FAIL + 1))
fi
