#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || realpath "$0")")" && pwd)"

# Detect runtime (docker, nerdctl, or finch)
if command -v docker &>/dev/null; then
    CONTAINER_RT=docker
elif command -v nerdctl &>/dev/null; then
    CONTAINER_RT=nerdctl
elif command -v finch &>/dev/null; then
    CONTAINER_RT=finch
else
    echo "Error: No container runtime found. Install docker, nerdctl, or finch." >&2
    exit 1
fi

# Check if venv exists and is up-to-date
VENV_DIR="$SCRIPT_DIR/.venv"
REQUIREMENTS_FILE="$SCRIPT_DIR/requirements.txt"

setup_venv() {
    # If the venv exists but doesn't work, recreate it
    if [[ -d "$VENV_DIR" ]]; then
        if ! "$VENV_DIR/bin/python3" -c "import yaml" 2>/dev/null; then
            echo "Recreating broken virtual environment..." >&2
            rm -rf "$VENV_DIR"
        fi
    fi

    if [[ ! -d "$VENV_DIR" ]]; then
        echo "Creating Python virtual environment..." >&2
        python3 -m venv "$VENV_DIR"
    fi

    source "$VENV_DIR/bin/activate"
    pip install --quiet --upgrade pip
    pip install --quiet -r "$REQUIREMENTS_FILE"
}

# Set up venv if needed
setup_venv

# Run Python implementation
exec "$VENV_DIR/bin/python3" "$SCRIPT_DIR/claude_docker.py" "$@"